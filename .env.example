# GitHub Personal Access Token for fetching pinned repositories
# Required for building the projects page.
#
# Create one at: https://github.com/settings/tokens?type=beta
#   - Token name: t-industries-pinned-repos
#   - Repository access: Public Repositories (read-only)
#   - Account permissions: basic read access
# Or use a classic token with `read:user` scope.
GH_PINNED_TOKEN=
